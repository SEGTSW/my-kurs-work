{
  "name": "test-task-insiders",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "scripts/run-microservices.ts",
  "scripts": {
    "start": "ts-node --files scripts/run-microservices.ts",
    "dev": "nodemon --watch services --watch scripts --ext ts --exec ts-node --files scripts/run-microservices.ts",
    "start:gateway": "ts-node --project services/api-gateway/tsconfig.json --files services/api-gateway/src/main.ts",
    "start:auth": "ts-node --project services/auth-service/tsconfig.json --files services/auth-service/src/main.ts",
    "start:rooms": "ts-node --project services/room-service/tsconfig.json --files services/room-service/src/main.ts",
    "start:bookings": "ts-node --project services/booking-service/tsconfig.json --files services/booking-service/src/main.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "dev:frontend": "npm run dev --prefix frontend",
    "build:frontend": "npm run build --prefix frontend"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "nodemon": "^3.1.14",
    "pg": "^8.20.0",
    "prisma": "^6.19.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
